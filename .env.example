APP_NAME=Face Attendance API
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=*
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/attendance_db
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
FACE_TOLERANCE=0.5
MAX_UPLOAD_MB=5
OFFICE_LATITUDE=37.7749
OFFICE_LONGITUDE=-122.4194
GEOFENCE_RADIUS_METERS=300
ATTENDANCE_COOLDOWN_MINUTES=10
ADMIN_DEFAULT_LIMIT=50
ADMIN_MAX_LIMIT=500
FACE_HASH_BITS=16
FACE_CANDIDATE_LIMIT=5000
MAX_FULL_SCAN_FACES=5000
PAYMENT_PROVIDER=demo
PAYMENT_CURRENCY=usd
PUBLIC_BASE_URL=http://127.0.0.1:8000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
